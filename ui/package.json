{
  "name": "@deepcrate/ui",
  "private": true,
  "version": "0.1.20",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --build",
    "lint:oxlint": "oxlint . -D correctness --ignore-path .gitignore",
    "lint:oxlint:fix": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --cache",
    "lint:eslint:fix": "eslint . --fix --cache",
    "lint": "run-s lint:*",
    "lint:fix": "run-s lint:*:fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "axios": "^1.13.6",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/eslint-plugin": "^1.6.12",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-plugin-cypress": "^6.2.0",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-vue": "^10.8.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vue-tsc": "^3.2.6"
  }
}
