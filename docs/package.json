{
  "name": "@deepcrate/docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vitepress dev",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "lint:oxlint": "oxlint . -D correctness --ignore-path .gitignore",
    "lint:oxlint:fix": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --cache",
    "lint:eslint:fix": "eslint . --fix --cache",
    "lint": "run-s lint:*",
    "lint:fix": "run-s lint:*:fix",
    "format": "prettier --write .vitepress/ src/"
  },
  "devDependencies": {
    "@eslint/markdown": "^7.5.1",
    "@prettier/plugin-oxc": "^0.1.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.0.3",
    "eslint-plugin-oxlint": "^1.54.0",
    "eslint-plugin-vue": "^10.8.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.54.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vitepress": "2.0.0-alpha.16"
  }
}
